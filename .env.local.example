# ────────────────────────────────────────────────────────────────────────────
# Rockstock 環境變數範本 — cp .env.local.example .env.local 後填入實值
# ────────────────────────────────────────────────────────────────────────────

# === 必填：Cron 共用密鑰 =====================================================
# 用於 /api/cron/* 路由身分驗證。本地 launchd + Vercel cron + 各種 script 都讀。
# 產生：openssl rand -base64 32
CRON_SECRET=replace-with-random-base64-string

# === 必填（生產）：Vercel Blob 儲存 ==========================================
# L1 歷史 K 線、scan session、lockwatch snapshot 等都用 Blob 存。
# Vercel dashboard → Storage → Blob → 取 token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# === 資料來源：台股 ==========================================================
# EODHD：跨市場最穩 fallback（5/13 backfill 863 檔靠它）
EODHD_API_TOKEN=your-eodhd-token

# FinMind：台股歷史 K 線主來源；token 失效會走 24h 熔斷
FINMIND_API_TOKEN=your-finmind-token

# Fugle：台股盤中 quote 補位（mis.twse 鎖漲跌停資料源）
FUGLE_API_KEY=your-fugle-key

# 富邦 Neo：台股即時報價備選（盤中 backup）
FUBON_NEO_API_KEY=your-fubon-key

# === AI 功能 =================================================================
# 問朱老師 / scan-coach / chart-coach 用
ANTHROPIC_API_KEY=sk-ant-api03-...

# MiniMax 包裝 Claude（用戶 Claude Code 本地代理；設了會優先用，沒設走 ANTHROPIC）
# MINIMAX_API_KEY=...
# MINIMAX_BASE_URL=https://...

# === 通知 ====================================================================
# Resend 郵件（選填）
RESEND_API_KEY=re_...
EMAIL_FROM=onboarding@resend.dev
NOTIFY_EMAIL=your-email@example.com

# 資料健康警示 webhook（選填，設了 daily-health-snapshot 紅燈會 POST 通知）
# Slack incoming webhook / Discord / ntfy.sh / 自建 endpoint 都吃。
# Payload: { text, level, dateKey, markets }
# HEALTH_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# HEALTH_ALERT_LEVEL=red    # 'red'（預設）= 只在紅燈推；'yellow' = 黃燈也推

# === 站點設定 ================================================================
# 對外公開網址，cron 內部呼叫用
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# NEXT_INTERNAL_BASE_URL=https://your-app.vercel.app    # 通常同 SITE_URL

# === Admin / 開發 ============================================================
# 管理頁 /admin/* 密鑰
# ADMIN_SECRET=replace-with-random
# SESSION_SECRET=replace-with-random
# UPLOAD_SECRET=replace-with-random

# 本地開發：DISABLE_LOCAL_CRON=1 npm run dev → 停用 instrumentation.ts 模擬 cron
# DISABLE_LOCAL_CRON=1
