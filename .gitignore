# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Python
__pycache__/
*.pyc

# data files (downloaded locally, not for git)
/data/*.csv
/data/*.json
/data/*.pkl
/data/*.png
/data/candles/

# strategy-engine (separate Python experiment)
/strategy-engine/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# certificates (sensitive)
*.pfx
*.p12
certs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.cache/

# Capacitor native build artifacts
/ios/App/Pods/
/ios/DerivedData/
/android/.gradle/
/android/app/build/
/android/build/
/android/local.properties
.env*.local
