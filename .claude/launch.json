{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-c", "export PATH=/usr/local/bin:$PATH && NODE_OPTIONS='--dns-result-order=ipv4first' node node_modules/next/dist/bin/next dev --port $PORT"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "prod",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-c", "export PATH=/usr/local/bin:$PATH && npm run start"],
      "port": 3000
    }
  ]
}
